# Copy to .env and fill in. NEVER commit the real .env.

# --- scoring (required for new tracks) ---
OPENAI_API_KEY=sk-...
# Lyrics come from LRCLIB / lyrics.ovh (free, no key, no scraping).
# GENIUS_ACCESS_TOKEN is no longer used and can be omitted.

# --- email delivery (Resend) ---
# Without RESEND_API_KEY the service prints emails to the log (dev mode).
RESEND_API_KEY=re_...
FROM_EMAIL=onboarding@resend.dev          # use a verified-domain address in production

# --- service ---
BASE_URL=http://localhost:8000            # public URL of the deployed service (for result links)
DATA_DIR=./data                           # where the track DB, jobs, uploads, results live
TRACK_DB_PATH=./data/track_library.db
MAX_UPLOAD_MB=60
RESULT_TTL_DAYS=30

# --- optional (Spotify URI resolution / album art; not required for GEMS) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
